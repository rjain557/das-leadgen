# das-leadgen — environment DOCUMENTATION ONLY. Never put real values here or
# anywhere in the repo. Credentials live ONLY in the OneDrive keys vault.
#
# load-env.js resolves credentials at runtime, in this order, filling only what
# is missing (the vault is the single source of truth — no secret is duplicated):
#   1. das-leadgen.env  (optional override file in the vault; not required)
#   2. bbc-leadgen.env  (reused keys: ATTOM, Google, BatchData, Spokeo, portal logins)
#   3. canonical vault files — automatically:
#        tech-leads-secrets.json → SERPAPI_KEY, HUNTER_API_KEY, ANTHROPIC_API_KEY
#        m365-graph.md           → GRAPH_CLIENT_ID / GRAPH_TENANT_ID / GRAPH_CLIENT_SECRET
#        opencorporates.md       → OPENCORPORATES_API_KEY (when the signup is finished)
# So NO das-leadgen.env is needed for the system to run — it self-wires from the
# vault. The variables below are listed only to document what the code reads.

# --- Reused from BBC (already in the vault — bbc-leadgen.env) ---------------
ATTOM_API_KEY=
GOOGLE_GEOCODING_API_KEY=
BATCHDATA_API_KEY=
BATCHLEADS_API_KEY=
SPOKEO_EMAIL=
SPOKEO_PASSWORD=
LITELLM_BASE_URL=
LITELLM_API_KEY=

# --- Reused from tech-leads (exist in vault; ADD to das-leadgen.env) --------
SERPAPI_KEY=
HUNTER_API_KEY=

# --- M365 Graph (reuse Technijian HiringPipeline-Automation app reg) --------
GRAPH_CLIENT_ID=
GRAPH_TENANT_ID=
GRAPH_CLIENT_SECRET=

# --- NEW for das-leadgen (obtain in Phase 0) --------------------------------
# Free Socrata app tokens (optional — raise rate limits; harvest works without them)
LA_SOCRATA_APP_TOKEN=
NASHVILLE_SOCRATA_APP_TOKEN=
# Optional — developer-entity resolution (LLC -> developer). Free tier works without.
OPENCORPORATES_API_KEY=

# --- Tuning / behavior flags ------------------------------------------------
DAS_BROWSER_DRIVER=          # patchright | stealth | playwright (blank = auto)
DAS_CONTACTS_MAX=50
DAS_EMAIL_ENABLED=false      # set true to actually send the weekly Brief
ANTHROPIC_API_KEY=           # optional — LLM contact extraction / entity resolution
